---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GalleryGrid from '../../components/GalleryGrid.astro';
import { getCreatorBySlug, getImagesByCreator } from '../../lib/pocketbase';
import type { Creator, Image } from '../../lib/types';

const { slug } = Astro.params;

let creator: Creator | null = null;
let images: Image[] = [];
let creatorError = false;
let imagesError = false;

try {
  creator = await getCreatorBySlug(slug!);
} catch (e) {
  console.error(`[creators/${slug}] Failed to fetch creator:`, e);
  Astro.response.status = 503;
  creatorError = true;
}

if (!creatorError && creator === null) {
  return new Response(null, { status: 404 });
}

if (creator) {
  try {
    images = await getImagesByCreator(creator.id);
  } catch (e) {
    console.error(`[creators/${slug}] Failed to fetch images:`, e);
    Astro.response.status = 503;
    imagesError = true;
  }
}

const avatarUrl = creator?.avatar ?? '';
---
<BaseLayout title={creator?.name ?? 'Creator'} description={creator?.bio}>
  <main>
    <a href="/" class="back-link">← All creators</a>
    
    {creatorError && <p class="error">Gallery unavailable — try again later.</p>}
    {creator && (
      <>
        <div class="creator-header">
          <img
            src={avatarUrl}
            alt={creator.name}
            class="creator-avatar-large"
            width="120"
            height="120"
            decoding="async"
          />
          <div class="creator-header-info">
            <h1>{creator.name}</h1>
            <p>{creator.bio}</p>
            {creator.external_link && (
              <a href={creator.external_link} class="external-link" target="_blank" rel="noopener noreferrer">
                Visit Link
              </a>
            )}
          </div>
        </div>
        {imagesError
          ? <p class="error">Images unavailable — try again later.</p>
          : <GalleryGrid images={images} creator={creator} />
        }
      </>
    )}
  </main>
</BaseLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: var(--gap);
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--text);
    text-decoration: none;
  }

  .creator-header {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: calc(var(--gap) * 2);
    flex-wrap: wrap;
    padding: 2rem;
    background: var(--surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--surface-hover);
  }

  .creator-header-info {
    flex: 1;
    min-width: 200px;
  }

  .creator-header-info h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    letter-spacing: 0.04em;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .creator-header-info p {
    color: var(--text-secondary);
    margin-bottom: 1rem;
    font-size: 1rem;
    line-height: 1.6;
  }

  .creator-avatar-large {
    width: 120px;
    height: 120px;
    border-radius: var(--radius-lg);
    object-fit: cover;
    flex-shrink: 0;
  }

  .external-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.2rem;
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--accent);
    transition: all 0.3s ease;
  }

  .external-link:hover {
    background: var(--accent);
    color: var(--bg);
    text-decoration: none;
    box-shadow: 0 0 20px var(--accent-glow);
  }
</style>