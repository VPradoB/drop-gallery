---
interface Props {
  backLink?: boolean;
}
const { backLink = false } = Astro.props;
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-title">
      <span class="title-text">Drops</span>
      <span class="title-accent">Gallery</span>
    </a>
    {backLink && <a href="/" class="back-link">← All creators</a>}
  </div>
  <div class="header-glow"></div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: linear-gradient(to bottom, var(--bg) 0%, rgba(8, 8, 8, 0.9) 60%, transparent 100%);
    padding: 1.5rem var(--gap) 2rem;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1400px;
    margin: 0 auto;
  }

  .header-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 100px;
    background: radial-gradient(ellipse 100% 100% at 50% 0%, var(--accent-glow) 0%, transparent 70%);
    opacity: 0.5;
    pointer-events: none;
  }

  .site-title {
    display: flex;
    align-items: center;
    gap: 0.1em;
    font-family: var(--font-display);
    font-size: 2rem;
    letter-spacing: 0.08em;
    text-decoration: none;
  }

  .title-text {
    color: var(--text);
  }

  .title-accent {
    color: var(--accent);
  }

  .site-title:hover {
    text-decoration: none;
  }

  .site-title:hover .title-accent {
    text-shadow: 0 0 20px var(--accent-glow), 0 0 40px var(--accent-glow);
  }

  .back-link {
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--text);
    text-decoration: none;
  }
</style>