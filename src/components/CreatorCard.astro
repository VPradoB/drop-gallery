---
import type { Creator, Image } from '../lib/types';

interface Props {
  creator: Creator;
  previewImages: Image[];
}
const { creator, previewImages } = Astro.props;
const previews = previewImages.slice(0, 3);
const count = previews.length;
---
<a href={`/creators/${creator.slug}`} class="creator-card">

  <div class={`card-preview preview-${count}`}>
    {count === 0
      ? <div class="preview-empty">Sin imágenes</div>
      : previews.map((img) => (
          <img src={img.file} alt={img.alt} loading="lazy" decoding="async" />
        ))
    }
    <div class="card-overlay"></div>
  </div>

  <div class="card-info">
    <img
      src={creator.avatar}
      alt={creator.name}
      class="card-avatar"
      width="40"
      height="40"
      loading="lazy"
      decoding="async"
    />
    <div class="card-meta">
      <span class="card-name">{creator.name}</span>
      <span class="card-bio">{creator.bio}</span>
    </div>
    <div class="card-arrow">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"/>
        <path d="m12 5 7 7-7 7"/>
      </svg>
    </div>
  </div>

</a>

<style>
  .creator-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    border: 1px solid transparent;
  }

  .creator-card:hover {
    transform: translateY(-6px);
    border-color: var(--accent);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 30px rgba(255, 45, 106, 0.2);
    text-decoration: none;
  }

  /* Preview area */
  .card-preview {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-alt);
    display: grid;
    gap: 2px;
    position: relative;
  }

  .card-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .creator-card:hover .card-preview img {
    transform: scale(1.08);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8, 8, 8, 0.6) 0%, transparent 50%);
    pointer-events: none;
  }

  .preview-0 { display: flex; align-items: center; justify-content: center; }
  .preview-empty { color: var(--text-muted); font-size: 0.85rem; }

  .preview-1 { grid-template-columns: 1fr; grid-template-rows: 1fr; }

  .preview-2 { grid-template-columns: 1fr 1fr; grid-template-rows: 1fr; }

  .preview-3 { grid-template-columns: 2fr 1fr; grid-template-rows: 1fr 1fr; }
  .preview-3 img:first-child { grid-row: 1 / 3; }

  /* Info bar */
  .card-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    flex-shrink: 0;
  }

  .card-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--surface-elevated);
  }

  .card-meta {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .card-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-bio {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-arrow {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface-hover);
    border-radius: 50%;
    color: var(--text-muted);
    transition: transform 0.3s ease, background 0.3s ease, color 0.3s ease;
    flex-shrink: 0;
  }

  .creator-card:hover .card-arrow {
    transform: translateX(4px);
    background: var(--accent);
    color: var(--bg);
  }
</style>