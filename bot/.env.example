# Telegram bot token from @BotFather
BOT_TOKEN=

# Comma-separated list of allowed Telegram user IDs (admins)
ALLOWED_USERS=123456789,987654321

# PocketBase URL
PB_URL=http://pocketbase:8080

# PocketBase admin credentials for auth
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=supersecret

# Path where media files are saved (must match web server's public dir)
MEDIA_PATH=/app/public/media

# Max upload size in bytes (default: 20MB)
MAX_FILE_SIZE=20971520
